# WeChat Pay Environment Configuration
# Copy this file to .env and fill in your actual values

# WeChat Pay Configuration
WECHAT_PAY_APP_ID=your_app_id_here
WECHAT_PAY_MCH_ID=your_mch_id_here
WECHAT_PAY_API_KEY=your_32_character_api_key_here

# Certificates (PEM format, single line)
# Convert using: awk '{printf "%s\\n", $0}' cert.pem
WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkq...
-----END PRIVATE KEY-----

WECHAT_PAY_PUBLIC_KEY=-----BEGIN CERTIFICATE-----
MIID8zCCAtugAwIB...
-----END CERTIFICATE-----

# WeChat Pay Public Key (Recommended, new verification method)
WECHAT_PAY_PAYMENT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MIIEvgIBADAN...
-----END PUBLIC KEY-----

WECHAT_PAY_PUBLIC_KEY_ID=your_public_key_id_here

# Server Configuration
PORT=3000
WEBHOOK_URL=http://localhost:3000/webhook/wechat

# Debug Mode (true for development, false for production)
WECHAT_PAY_DEBUG=true
