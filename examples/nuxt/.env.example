# WeChat Pay Credentials
WECHAT_PAY_APP_ID=wxYourAppID
WECHAT_PAY_MCH_ID=1234567890
WECHAT_PAY_API_KEY=your_32_character_api_key

# Certificates (PEM format, single line)
WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w...
-----END PRIVATE KEY-----

WECHAT_PAY_PUBLIC_KEY=-----BEGIN CERTIFICATE-----
MIID8zCCAtugAwIB...
-----END CERTIFICATE-----

# WeChat Pay public key (recommended)
WECHAT_PAY_PAYMENT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MIIEvgIBADAN...
-----END PUBLIC KEY-----

WECHAT_PAY_PUBLIC_KEY_ID=serial_number

# Webhook URL
NUXT_PUBLIC_WEBHOOK_URL=http://localhost:3000/api/wechatpay/webhook
WECHAT_PAY_NOTIFY_URL=http://localhost:3000/api/wechatpay/webhook

# Debug mode
WECHAT_PAY_DEBUG=true
